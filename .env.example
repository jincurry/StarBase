# --- HTTP server -------------------------------------------------------------
STARBASE_HTTP_ADDR=:8080
STARBASE_PUBLIC_URL=http://localhost:8080
STARBASE_WEB_URL=http://localhost:3000

# --- PostgreSQL --------------------------------------------------------------
STARBASE_DB_URL=postgres://starbase:starbase@localhost:5432/starbase?sslmode=disable

# --- GitHub OAuth ------------------------------------------------------------
STARBASE_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
STARBASE_GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
STARBASE_GITHUB_CALLBACK=http://localhost:8080/api/auth/github/callback

# --- Session / token encryption ---------------------------------------------
# 32-byte hex string used to encrypt OAuth access tokens at rest (AES-256-GCM).
STARBASE_TOKEN_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
STARBASE_SESSION_SECRET=please-change-me-to-a-long-random-string

# --- Sync worker -------------------------------------------------------------
STARBASE_WORKER_CONCURRENCY=2
STARBASE_GITHUB_RATE_PER_SEC=1
